        "@types/bcryptjs": "2.4.6",
        "@types/js-yaml": "4.0.9",
        "@types/node": "^22.13.13",
        "@types/uuid": "10.0.0",
        "@typescript-eslint/utils": "^8.28.0",
        "coveralls": "^3.0.2",
        "eslint": "^9.25.1",
        "eslint-plugin-command": "^3.2.0",
        "eslint-plugin-format": "^1.0.1",
        "mocha": "^5.2.0",
